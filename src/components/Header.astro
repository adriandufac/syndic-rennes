---
const navLinks = [
  { href: '/syndics-rennes', label: 'Les syndics' },
  { href: '/prix-syndic-rennes', label: 'Prix' },
  { href: '/changer-syndic-rennes', label: 'Changer de syndic' },
  { href: '/#comment-ca-marche', label: 'Comment ça marche' },
];
---

<header class="bg-primary text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="font-heading text-xl font-bold tracking-tight">
      SyndicRennes.fr
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a href={link.href} class="hover:text-accent transition-colors text-sm font-medium">
          {link.label}
        </a>
      ))}
      <a
        href="#formulaire"
        data-source="header"
        class="bg-accent hover:bg-orange-500 text-white px-5 py-2 rounded-lg font-heading font-semibold text-sm transition-colors"
      >
        Être mis en relation
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-white transition-transform" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-opacity" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white transition-transform" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="md:hidden hidden bg-primary border-t border-white/10 px-4 pb-4">
    {navLinks.map(link => (
      <a href={link.href} class="block py-2 hover:text-accent transition-colors text-sm">
        {link.label}
      </a>
    ))}
    <a
      href="#formulaire"
      data-source="header-mobile"
      class="block mt-2 bg-accent hover:bg-orange-500 text-white text-center px-5 py-2 rounded-lg font-heading font-semibold text-sm transition-colors"
    >
      Être mis en relation
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
