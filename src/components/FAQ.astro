---
interface Props {
  items: { question: string; answer: string }[];
}
const { items } = Astro.props;
---

<section class="max-w-3xl mx-auto py-12">
  <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary text-center mb-8">
    Questions fréquentes
  </h2>
  <div class="space-y-4">
    {items.map((item, i) => (
      <details class="bg-white rounded-xl shadow-sm border border-gray-100 group" >
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 font-heading font-semibold text-text hover:text-primary transition-colors">
          <span>{item.question}</span>
          <span class="ml-4 text-accent group-open:rotate-45 transition-transform text-xl font-bold">+</span>
        </summary>
        <div class="px-6 pb-5 text-sm text-text/70 leading-relaxed">
          {item.answer}
        </div>
      </details>
    ))}
  </div>
</section>
