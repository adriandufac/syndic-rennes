---
import type { Syndic } from '../data/syndics';
import { typeLabels } from '../data/syndics';

interface Props {
  syndic: Syndic;
}
const { syndic } = Astro.props;

const tailleLabel = syndic.tailleAdaptee.max
  ? `${syndic.tailleAdaptee.min} à ${syndic.tailleAdaptee.max} lots`
  : `${syndic.tailleAdaptee.min}+ lots`;

const badgeColors: Record<Syndic["type"], string> = {
  independant: "bg-green-100 text-green-800",
  reseau_national: "bg-blue-100 text-blue-800",
  cabinet_regional: "bg-purple-100 text-purple-800",
};
---

<div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col justify-between border border-gray-100 hover:shadow-xl transition-shadow">
  <div>
    <div class="flex items-center justify-between mb-3 gap-2">
      <h3 class="font-heading text-lg font-bold text-primary">{syndic.nom}</h3>
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap ${badgeColors[syndic.type]}`}>
        {typeLabels[syndic.type]}
      </span>
    </div>

    <div class="space-y-2 text-sm text-text/70 mb-4">
      <p><span class="font-medium text-text">Zone :</span> {syndic.zoneIntervention.join(', ')}</p>
      <p><span class="font-medium text-text">Taille adaptée :</span> {tailleLabel}</p>
      <p><span class="font-medium text-text">Tarifs :</span> <span class="font-semibold text-primary">{syndic.fourchettePrix.min} – {syndic.fourchettePrix.max} €</span> / lot / an</p>
    </div>

    <ul class="space-y-1 mb-4">
      {syndic.pointsForts.map(p => (
        <li class="flex items-start gap-2 text-sm text-text/70">
          <span class="text-accent mt-0.5">&#10003;</span>
          <span>{p}</span>
        </li>
      ))}
    </ul>

    <div class="flex flex-wrap gap-1.5 mb-5">
      {syndic.convientPour.map(tag => (
        <span class="text-xs bg-bg text-text/60 px-2.5 py-1 rounded-full">{tag}</span>
      ))}
    </div>
  </div>

  <a
    href="#formulaire"
    data-source={`syndic-card-${syndic.id}`}
    class="block text-center bg-accent hover:bg-orange-500 text-white font-heading font-semibold py-2.5 rounded-xl transition-colors text-sm"
  >
    Ce cabinet correspond à mon profil &rarr;
  </a>
</div>
