---
const steps = [
  {
    number: "1",
    title: "Décrivez votre copropriété",
    description: "Nombre de lots, type d'immeuble, situation actuelle — en 2 minutes, on comprend votre besoin.",
  },
  {
    number: "2",
    title: "Nous sélectionnons les syndics adaptés",
    description: "On analyse votre profil et on contacte uniquement les cabinets correspondant à votre taille et secteur.",
  },
  {
    number: "3",
    title: "Des syndics partenaires peuvent vous contacter",
    description: "Si votre profil correspond, des syndics qualifiés vous recontactent avec une proposition adaptée.",
  },
];
---

<section id="comment-ca-marche" class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary text-center mb-12">
      Comment fonctionne notre service ?
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map(step => (
        <div class="text-center">
          <div class="w-14 h-14 bg-accent text-white font-heading font-bold text-2xl rounded-full flex items-center justify-center mx-auto mb-4">
            {step.number}
          </div>
          <h3 class="font-heading font-bold text-primary mb-2">{step.title}</h3>
          <p class="text-sm text-text/70 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-xs text-text/50 mt-8">Gratuit &middot; Sans engagement</p>
  </div>
</section>
